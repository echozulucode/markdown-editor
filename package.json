{
  "name": "markdown-editor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @markdown-editor/dev-harness test:e2e",
    "typecheck": "pnpm -r typecheck",
    "dev:harness": "pnpm --filter @markdown-editor/dev-harness dev"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
