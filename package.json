{
  "name": "markdown-editor",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for the echozed markdown editor — a React markdown editor with Markdown, Hybrid, Preview, and Rich Text modes.",
  "license": "MIT",
  "author": "Eric Zimmerman (https://echozed.com)",
  "homepage": "https://echozed.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/echozulucode/markdown-editor.git"
  },
  "bugs": {
    "url": "https://github.com/echozulucode/markdown-editor/issues"
  },
  "type": "module",
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @echozedlabs/dev-harness test:e2e",
    "typecheck": "pnpm -r typecheck",
    "dev:harness": "pnpm --filter @echozedlabs/dev-harness dev",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/node": "^22.7.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
