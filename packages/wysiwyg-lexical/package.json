{
  "name": "@echozedlabs/wysiwyg-lexical",
  "version": "0.1.0",
  "description": "Lexical-powered rich-text (WYSIWYG) markdown editing surface for the echozed markdown editor.",
  "type": "module",
  "license": "MIT",
  "author": "Eric Zimmerman (https://echozed.com)",
  "homepage": "https://echozed.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/echozulucode/markdown-editor.git",
    "directory": "packages/wysiwyg-lexical"
  },
  "bugs": {
    "url": "https://github.com/echozulucode/markdown-editor/issues"
  },
  "keywords": [
    "markdown",
    "wysiwyg",
    "lexical",
    "rich-text",
    "editor"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "dist",
    "src/styles.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run && tsc -p tsconfig.test.json --noEmit",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@lexical/code": "^0.44.0",
    "@lexical/link": "^0.44.0",
    "@lexical/list": "^0.44.0",
    "@lexical/markdown": "^0.44.0",
    "@lexical/react": "^0.44.0",
    "@lexical/rich-text": "^0.44.0",
    "@lexical/selection": "^0.44.0",
    "@lexical/table": "^0.44.0",
    "@echozedlabs/core": "workspace:*",
    "dompurify": "^3.4.3",
    "lexical": "^0.44.0",
    "mermaid": "^11.15.0"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "jsdom": "^24.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.4"
  }
}
