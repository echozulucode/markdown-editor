{
  "name": "@echozedlabs/react",
  "version": "0.2.0",
  "description": "React markdown editor with Markdown, Hybrid, Preview, and Rich Text (WYSIWYG) modes — the echozed markdown editor.",
  "type": "module",
  "license": "MIT",
  "author": "Eric Zimmerman (https://echozed.com)",
  "homepage": "https://echozed.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/echozulucode/markdown-editor.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/echozulucode/markdown-editor/issues"
  },
  "keywords": [
    "markdown",
    "editor",
    "react",
    "wysiwyg",
    "rich-text",
    "lexical",
    "codemirror",
    "markdown-editor"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "dist",
    "src/styles.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@echozedlabs/codemirror": "workspace:*",
    "@echozedlabs/core": "workspace:*",
    "@echozedlabs/renderers": "workspace:*",
    "@echozedlabs/wysiwyg-lexical": "workspace:*",
    "dompurify": "^3.4.3"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "jsdom": "^24.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
