{
  "name": "@echozedlabs/codemirror",
  "version": "0.2.0",
  "description": "CodeMirror 6 source/hybrid markdown editing surface for the echozed markdown editor.",
  "type": "module",
  "license": "MIT",
  "author": "Eric Zimmerman (https://echozed.com)",
  "homepage": "https://echozed.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/echozulucode/markdown-editor.git",
    "directory": "packages/codemirror"
  },
  "bugs": {
    "url": "https://github.com/echozulucode/markdown-editor/issues"
  },
  "keywords": [
    "markdown",
    "codemirror",
    "editor",
    "source-editing"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run && tsc -p tsconfig.test.json --noEmit",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@echozedlabs/core": "workspace:*",
    "@codemirror/commands": "^6.10.0",
    "@codemirror/lang-markdown": "^6.3.4",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.8"
  },
  "devDependencies": {
    "jsdom": "^24.1.3",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
